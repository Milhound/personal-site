{
  "name": "personal-site",
  "version": "1.0.0",
  "description": "Daniel Milholland's personal site",
  "main": "server.ts",
  "scripts": {
    "start": "tsx server.ts",
    "dev": "concurrently \"tsx server.ts\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client",
    "install-all": "npm install && npm install --prefix client",
    "test:routes": "npm run build --prefix client && tsx --test test/routes.test.ts"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "express": "^5.2.1",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "supertest": "^7.2.2",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3"
  }
}
