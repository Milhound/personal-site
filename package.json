{
  "name": "personal-site",
  "version": "1.0.0",
  "description": "Daniel Milholland's personal site",
  "main": "server.ts",
  "scripts": {
    "start": "tsx server.ts",
    "dev": "concurrently \"tsx server.ts\" \"npm run dev --prefix client\"",
    "build": "npm run build --prefix client",
    "install-all": "npm install && npm install --prefix client",
    "test:routes": "npm run build --prefix client && tsx --test test/routes.test.ts"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^22.15.30",
    "@types/supertest": "^6.0.3",
    "concurrently": "^8.2.0",
    "supertest": "^7.1.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
