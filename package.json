{
  "name": "personal-site",
  "version": "1.0.0",
  "description": "Daniel Milholland's personal site",
  "main": "server.ts",
  "scripts": {
    "start": "bun ./build/server.js",
    "dev": "concurrently \"tsx server.ts\" \"bun run dev --cwd client\"",
    "build": "bun build ./server.ts --outdir ./build --target bun",
    "install-all": "bun install && bun install --cwd client",
    "test:routes": "bun build ./server.ts --outdir ./build --target bun && tsx --test test/routes.test.ts"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "express": "^5.2.1",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/supertest": "^7.2.0",
    "concurrently": "^10.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
